# BotChat production environment
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=0

# Database
DB_NAME=django_db
DB_USER=django_user
DB_PASSWORD=replace-with-production-db-password
DB_HOST=botchat-db
DB_PORT=5432

# Gemini
GEMINI_API_KEY=replace-with-production-gemini-api-key

# Redis
REDIS_URL=redis://botchat-redis:6379/0

# Retrieval defaults
EMBEDDING_DIM=768
TOPK=6

# Frontend origin used by the embedded BotChat app
VITE_API_BASE=https://www.thomasspike.com/botchat-api